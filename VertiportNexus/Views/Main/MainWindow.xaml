<Window x:Class="VertiportNexus.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Vertiport Nexus Middleware"
        Width="1600"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#20242A">

    <Window.Resources>
        <!-- 공통 패널 스타일 -->
        <Style x:Key="PanelBorderStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#5F6870"/>
            <Setter Property="BorderBrush" Value="#9AA3AD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 공통 제목 스타일 -->
        <Style x:Key="PanelTitleStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 공통 버튼 스타일 -->
        <Style x:Key="DeviceControlButtonStyle"
               TargetType="Button">
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Height"
                    Value="30"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Opacity"
                            Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- [장비 연결] 버튼 스타일 -->
        <Style x:Key="ConnectButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#2F4F5F"/>
        </Style>

        <!-- [연결 해제] 버튼 스타일 -->
        <Style x:Key="DisconnectButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#4A2F2F"/>
        </Style>

        <!-- [PAN/TILT] 방향 버튼 스타일 -->
        <Style x:Key="PanTiltDirectionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#37474F"/>
            <Setter Property="Margin"
                    Value="4"/>
            <Setter Property="Width"
                    Value="32"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="18"/>
        </Style>

        <!-- [STOP] 버튼 스타일 -->
        <Style x:Key="StopButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#7A2525"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="BorderBrush"
                    Value="#708090"/>
            <Setter Property="FontSize"
                    Value="10"/>
        </Style>

        <!-- [EO] 제어 버튼 스타일 -->
        <Style x:Key="EoControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#30475A"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="12"/>
        </Style>

        <!-- [Auto Focus] 버튼 스타일 -->
        <Style x:Key="AutoFocusButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background" 
                    Value="#453666"/>
        </Style>
    </Window.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- 상단 상태 영역 -->
        <Border Grid.Row="0"
                Padding="12"
                Margin="0,0,0,10"
                Background="#2B3038"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Vertiport Nexus Middleware"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"/>

                <TextBlock Text="{Binding MainStatusText, Mode=OneWay}"
           Foreground="#5F86B3"
           FontSize="14"
           FontWeight="SemiBold"
           Margin="0,6,0,0"/>

                <TextBlock Text="{Binding OperationModeText, Mode=OneWay}"
           Foreground="#6E9E67"
           FontSize="14"
           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- 본문 영역 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 영상 영역 크게 -->
                <ColumnDefinition Width="5*"/>

                <!-- 제어 영역 작게 -->
                <ColumnDefinition Width="1.25*"/>
            </Grid.ColumnDefinitions>

            <!-- EO 영상 확인용 영역 -->
            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Background="Black"
                    BorderBrush="#5A5A5A"
                    BorderThickness="2">
                <Grid>
                    <Image Source="{Binding EOCameraImage, Mode=OneWay}"
                           Stretch="Uniform"/>
                </Grid>
            </Border>

            <!-- 우측 제어 영역 -->
            <!-- 우측 제어 패널 -->
            <Border Grid.Column="1"
                    Margin="0,0,0,0"
                    Background="#646A71"
                    BorderBrush="#8B949E"
                    BorderThickness="2"
                    CornerRadius="5"
                    Padding="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 연결 해제 -->
                    <Button Grid.Row="0"
                            Height="34"
                            Margin="0,0,0,5"
                            Content="연결 해제"
                            Style="{StaticResource DisconnectButtonStyle}"
                            Command="{Binding StopTcpReceiveCommand}"/>

                    <!-- 장비 연결 -->
                    <Button Grid.Row="1"
                            Height="34"
                            Width="130"
                            HorizontalAlignment="Left"
                            Content="장비 연결"
                            Style="{StaticResource ConnectButtonStyle}"
                            Command="{Binding StartTcpReceiveCommand}"/>

                    <!-- 장비 연결 / 제어 패널 -->
                    <Border Grid.Row="3"
                            Background="#5F666D"
                            BorderBrush="#95A5B0"
                            BorderThickness="1.5"
                            Padding="3">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 제목 -->
                            <TextBlock Grid.Row="0"
                                       Text="장비 연결"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>

                            <!-- 제어 패널 Scroll 영역 -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">

                                <StackPanel Orientation="Vertical"
                                            Margin="0,0,0,10">

                                    <!-- 장비 연결 설정 -->
                                    <Border Margin="0,10,10,0"
                                            Background="#5F666D"
                                            BorderBrush="#95A5B0"
                                            BorderThickness="1.5"
                                            Padding="10">

                                        <StackPanel>

                                            <TextBlock Text="장비 연결 설정"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,8"/>

                                            <!-- MCB 통신 설정 -->
                                            <Border Background="#40464D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1"
                                                    Padding="8"
                                                    Margin="0,0,0,8">

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="65"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Row="0"
                                                          Grid.Column="0"
                                                          Grid.ColumnSpan="3"
                                                          Margin="0,0,0,6">

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="MCB 통신 설정"
                                                                   Foreground="White"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding McbConnectionStatusText}"
                                                                   Foreground="{Binding McbConnectionStatusBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"/>
                                                    </Grid>

                                                    <!-- [MCB] IP 설정 -->
                                                    <TextBox Grid.Row="1"
                                                             Grid.Column="1"
                                                             Text="{Binding McbIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                                             Height="24"
                                                             FontSize="12"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"
                                                             Margin="0,0,5,0"/>

                                                    <!-- [MCB] Port 설정 -->
                                                    <TextBox Grid.Row="1"
                                                             Grid.Column="2"
                                                             Text="{Binding McbPort, UpdateSourceTrigger=PropertyChanged}"
                                                             Height="24"
                                                             FontSize="12"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <!-- SCB 통신 설정 -->
                                            <Border Background="#40464D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1"
                                                    Padding="8">

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="65"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Row="0"
                                                          Grid.Column="0"
                                                          Grid.ColumnSpan="3"
                                                          Margin="0,0,0,6">

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="SCB 통신 설정"
                                                                   Foreground="White"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ScbConnectionStatusText}"
                                                                   Foreground="{Binding ScbConnectionStatusBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"/>
                                                    </Grid>

                                                    <!-- [SCB] IP 설정 -->
                                                    <TextBox Grid.Row="1"
                                                             Grid.Column="1"
                                                             Text="{Binding ScbIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                                             Height="24"
                                                             FontSize="12"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"
                                                             Margin="0,0,5,0"/>

                                                    <!-- [SCB] Port 설정 -->
                                                    <TextBox Grid.Row="1"
                                                             Grid.Column="2"
                                                             Text="{Binding ScbPort, UpdateSourceTrigger=PropertyChanged}"
                                                             Height="24"
                                                             FontSize="12"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                        </StackPanel>
                                    </Border>

                                    <!-- PAN / TILT CONTROL -->
                                    <Border Margin="0,10,10,0"
                                            Background="#5F666D"
                                            BorderBrush="#95A5B0"
                                            BorderThickness="1.5"
                                            Padding="10">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="PAN / TILT CONTROL"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,5"/>

                                            <Grid Grid.Row="1"
                                                  Width="120"
                                                  Height="120"
                                                  HorizontalAlignment="Center">

                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>

                                                <!-- [TILT] [UP] -->
                                                <Button Grid.Row="0"
                                                        Grid.Column="1"
                                                        Content="▲"
                                                        Style="{StaticResource PanTiltDirectionButtonStyle}"
                                                        PreviewMouseDown="TiltUp_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- [PAN] [LEFT] -->
                                                <Button Grid.Row="1"
                                                        Grid.Column="0"
                                                        Content="◀"
                                                        Style="{StaticResource PanTiltDirectionButtonStyle}"
                                                        PreviewMouseDown="PanLeft_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- [STOP] -->
                                                <Border Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="5"
                                                        Background="#3F454B"
                                                        BorderBrush="#8B949E"
                                                        BorderThickness="1">

                                                    <Button Content="STOP"
                                                            Style="{StaticResource StopButtonStyle}"
                                                            Command="{Binding StopMoveCommand}"/>
                                                </Border>

                                                <!-- [PAN] [RIGHT] -->
                                                <Button Grid.Row="1"
                                                        Grid.Column="2"
                                                        Content="▶"
                                                        Style="{StaticResource PanTiltDirectionButtonStyle}"
                                                        PreviewMouseDown="PanRight_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- [TILT] [DOWN] -->
                                                <Button Grid.Row="2"
                                                        Grid.Column="1"
                                                        Content="▼"
                                                        Style="{StaticResource PanTiltDirectionButtonStyle}"
                                                        PreviewMouseDown="TiltDown_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>
                                            </Grid>

                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding PanTiltSpeedLevel,StringFormat=PT SPEED LV : {0} deg/s}"
                                                       Foreground="#D0D7DE"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- ZOOM / FOCUS CONTROL -->
                                    <Border Margin="0,10,10,0"
                                            Background="#5F666D"
                                            BorderBrush="#95A5B0"
                                            BorderThickness="1.5"
                                            Padding="10">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 제목 -->
                                            <TextBlock Grid.Row="0"
                                                       Text="ZOOM / FOCUS CONTROL"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,5"/>

                                            <!-- [EO] [ZOOM] 제어 -->
                                            <StackPanel Grid.Row="1"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,10">

                                                <!-- [EO] [ZOOM] 확대 -->
                                                <Button Content="ZOOM +"
                                                        Width="85"
                                                        Margin="5"
                                                        Focusable="False"
                                                        Style="{StaticResource EoControlButtonStyle}"
                                                        PreviewMouseDown="ZoomIn_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- [EO] [ZOOM] 축소 -->
                                                <Button Content="ZOOM -"
                                                        Width="85"
                                                        Margin="5"
                                                        Focusable="False"
                                                        Style="{StaticResource EoControlButtonStyle}"
                                                        PreviewMouseDown="ZoomOut_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>
                                            </StackPanel>

                                            <!-- [EO] [FOCUS] 제어 -->
                                            <StackPanel Grid.Row="2"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,10">

                                                <!-- [EO] [FOCUS] [Far] -->
                                                <Button Content="FOCUS +"
                                                        Width="85"
                                                        Margin="5"
                                                        Focusable="False"
                                                        Style="{StaticResource EoControlButtonStyle}"
                                                        PreviewMouseDown="FocusFar_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>

                                                <!-- [EO] [FOCUS] [Near] -->
                                                <Button Content="FOCUS -"
                                                        Width="85"
                                                        Margin="5"
                                                        Focusable="False"
                                                        Style="{StaticResource EoControlButtonStyle}"
                                                        PreviewMouseDown="FocusNear_MouseDown"
                                                        PreviewMouseUp="MoveStop_MouseUp"
                                                        MouseLeave="MoveStop_MouseUp"/>
                                            </StackPanel>

                                            <Button Grid.Row="3"
                                                    Content="AUTO FOCUS"
                                                    Width="180"
                                                    Margin="5"
                                                    HorizontalAlignment="Center"
                                                    Style="{StaticResource AutoFocusButtonStyle}"
                                                    Command="{Binding AutoFocusCommand}"/>
                                        </Grid>
                                    </Border>

                                    <!-- 상태 표시 -->
                                    <Border Margin="0,10,10,0"
                                            Background="#5F666D"
                                            BorderBrush="#95A5B0"
                                            BorderThickness="1.5"
                                            Padding="10">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="STATUS"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="1"
                                                       Text="PAN / TILT / ZOOM / FOCUS"
                                                       Foreground="White"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,4"/>

                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding CurrentPan, Mode=OneWay, StringFormat=Pan : {0:F2}}"
                                                       Foreground="White"
                                                       FontSize="12"/>

                                            <TextBlock Grid.Row="3"
                                                       Text="{Binding CurrentTilt, Mode=OneWay, StringFormat=Tilt : {0:F2}}"
                                                       Foreground="White"
                                                       FontSize="12"/>

                                            <TextBlock Grid.Row="4"
                                                       Text="{Binding CurrentZoom, Mode=OneWay, StringFormat=Zoom : {0:F2}}"
                                                       Foreground="White"
                                                       FontSize="12"/>

                                            <TextBlock Grid.Row="5"
                                                       Text="{Binding CurrentFocus, Mode=OneWay, StringFormat=Focus : {0:F2}}"
                                                       Foreground="White"
                                                       FontSize="12"/>
                                        </Grid>
                                    </Border>

                                </StackPanel>

                            </ScrollViewer>

                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 상태 바 -->
        <Border Grid.Row="3"
                Padding="8"
                Margin="0,8,0,0"
                Background="#2B3038">
            <TextBlock Text="CSE Middleware Test UI - Console log enabled"
                       Foreground="#B8C7D9"
                       FontSize="12"/>
        </Border>
    </Grid>
</Window>