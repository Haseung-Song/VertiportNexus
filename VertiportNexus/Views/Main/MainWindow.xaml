<Window x:Class="VertiportNexus.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Vertiport Nexus Middleware"
        Width="1920"
        Height="1080"
        WindowStartupLocation="CenterScreen"
        Background="#20242A">

    <Window.Resources>

        <!-- 공통 패널 스타일 -->
        <Style x:Key="PanelBorderStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#5F6870"/>
            <Setter Property="BorderBrush" Value="#9AA3AD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 공통 제목 스타일 -->
        <Style x:Key="PanelTitleStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>


        <!-- 공통 버튼 스타일 -->
        <Style x:Key="DeviceControlButtonStyle"
               TargetType="Button">
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Height"
                    Value="30"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Opacity"
                            Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- [장비 연결] 버튼 스타일 -->
        <Style x:Key="ConnectButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#2F4F5F"/>
        </Style>

        <!-- [연결 해제] 버튼 스타일 -->
        <Style x:Key="DisconnectButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#4A2F2F"/>
        </Style>

        <!-- [PAN/TILT] 방향 버튼 스타일 -->
        <Style x:Key="PanTiltDirectionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#37474F"/>
            <Setter Property="Margin"
                    Value="4"/>
            <Setter Property="Width"
                    Value="32"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="18"/>
        </Style>

        <!-- [STOP] 버튼 스타일 -->
        <Style x:Key="StopButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#7A2525"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="BorderBrush"
                    Value="#708090"/>
            <Setter Property="FontSize"
                    Value="10"/>
        </Style>

        <!-- [EO] 제어 버튼 스타일 -->
        <Style x:Key="EoControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background"
                    Value="#30475A"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="12"/>
        </Style>

        <!-- [Auto Focus] 버튼 스타일 -->
        <Style x:Key="AutoFocusButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DeviceControlButtonStyle}">
            <Setter Property="Background" 
                    Value="#453666"/>
        </Style>

        <!-- [우측 제어 패널] TabItem 스타일 -->
        <Style x:Key="RightPanelTabItemStyle"
               TargetType="TabItem">

            <Setter Property="Foreground"
                    Value="#D0D7DE"/>

            <Setter Property="FontWeight"
                    Value="Bold"/>

            <Setter Property="FontSize"
                    Value="12"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">

                        <!-- Tab Header 외곽 -->
                        <Border x:Name="TabBorder"
                                Background="#4F5860"
                                BorderBrush="#95A5B0"
                                BorderThickness="1,1,1,0"
                                CornerRadius="5,5,0,0"
                                Padding="60,6">

                            <!-- Tab Header Text 표시 -->
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- 선택된 Tab 색상 -->
                            <Trigger Property="IsSelected"
                                     Value="True">

                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="#5F666D"/>

                                <Setter TargetName="TabBorder"
                                        Property="BorderBrush"
                                        Value="#95A5B0"/>

                                <Setter Property="Foreground"
                                        Value="White"/>
                            </Trigger>

                            <!-- 마우스 오버 색상 -->
                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="#3B5F70"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

    </Window.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="75"/>
        </Grid.RowDefinitions>

        <!-- 상단 상태 영역 -->
        <Border Grid.Row="0"
                Padding="12"
                Margin="0,0,0,10"
                Background="#2B3038"
                CornerRadius="6">

            <StackPanel>
                <TextBlock Text="Vertiport Nexus Middleware"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"/>

                <TextBlock Text="{Binding MainStatusText, Mode=OneWay}"
                                          Foreground="#5F86B3"
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          Margin="0,6,0,0"/>

                <TextBlock Text="{Binding OperationModeText, Mode=OneWay}"
                                          Foreground="#6E9E67"
                                          FontSize="14"
                                          FontWeight="SemiBold"/>
            </StackPanel>

        </Border>

        <!-- 본문 영역 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- EO 영상 영역 -->
                <ColumnDefinition Width="*"/>

                <!-- 우측 제어 패널 -->
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- EO 영상 확인용 영역 -->
            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Background="Black"
                    BorderBrush="#5A5A5A"
                    BorderThickness="2">

                <Grid>
                    <Image Source="{Binding EOCameraImage, Mode=OneWay}"
                           Stretch="Uniform"/>
                </Grid>

            </Border>

            <!-- 우측 제어 패널 -->
            <Border Grid.Column="1"
                    Background="#646A71"
                    BorderBrush="#8B949E"
                    BorderThickness="2"
                    CornerRadius="5"
                    Padding="8">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 연결 해제 -->
                    <Button Grid.Row="0"
                            Height="34"
                            Margin="0,0,0,5"
                            Content="연결 해제"
                            Style="{StaticResource DisconnectButtonStyle}"
                            Command="{Binding StopTcpReceiveCommand}"/>

                    <!-- 장비 연결 -->
                    <Button Grid.Row="1"
                            Height="34"
                            Width="130"
                            Margin="0,0,0,5"
                            HorizontalAlignment="Left"
                            Content="장비 연결"
                            Style="{StaticResource ConnectButtonStyle}"
                            Command="{Binding StartTcpReceiveCommand}"/>

                    <!-- 장비 연결 / 제어 패널 -->
                    <Border Grid.Row="2"
                            Background="#5F666D"
                            BorderBrush="#95A5B0"
                            BorderThickness="1.5"
                            CornerRadius="5"
                            Padding="10">

                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- 제어 패널 제목 영역 -->
                                <RowDefinition Height="Auto"/>

                                <!-- 기능별 Tab 영역 -->
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 우측 제어 패널 제목 -->
                            <TextBlock Grid.Row="0"
                                       Text="장비 제어"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <!--
                                [우측 제어 패널] Tab 구성

                                1) [운용 제어]
                                2) [위치 제어]
                                3) [ZOOM / FOCUS]

                                영상 영역은 유지하고,
                                우측 제어 영역만 기능별로 전환한다.
                            -->
                            <TabControl Grid.Row="1"
                                        Background="#5F666D"
                                        BorderBrush="#95A5B0"
                                        Foreground="White"
                                        ItemContainerStyle="{StaticResource RightPanelTabItemStyle}">

                                <!--
                                    [운용 제어] Tab
                                
                                    1) [MCB / SCB] 연결 대상 정보와
                                    2) 연결 상태를 표시한다.
                                -->
                                <TabItem Header="운용 제어">

                                    <!-- [운용 제어] Tab 내부 Scroll 영역 -->
                                    <ScrollViewer VerticalScrollBarVisibility="Visible"
                                                  HorizontalScrollBarVisibility="Disabled">

                                        <StackPanel Margin="5">

                                            <!-- [운용 제어 설정 영역 -->
                                            <Border Margin="0,0,0,5"
                                                    Background="#5F666D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1.5"
                                                    CornerRadius="5"
                                                    Padding="10">

                                                <StackPanel>

                                                    <!-- [MCB/SCB 통신] 설정 제목 -->
                                                    <TextBlock Text="MCB, SCB 통신 설정"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,10"/>

                                                    <!-- [MCB 통신] 설정 영역 -->
                                                    <Border Background="#40464D"
                                                            BorderBrush="#95A5B0"
                                                            BorderThickness="1"
                                                            Padding="8"
                                                            Margin="0,0,0,10">

                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <!-- [MCB 제목 / 상태] 표시 -->
                                                                <RowDefinition Height="Auto"/>

                                                                <!-- [MCB IP / Port] 입력 -->
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <Grid.ColumnDefinitions>
                                                                <!-- 여백용 Column -->
                                                                <ColumnDefinition Width="Auto"/>

                                                                <!-- IP 입력 Column -->
                                                                <ColumnDefinition Width="*"/>

                                                                <!-- Port 입력 Column -->
                                                                <ColumnDefinition Width="65"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- [MCB 제목 및 연결 상태] 표시 -->
                                                            <Grid Grid.Row="0"
                                                                  Grid.Column="0"
                                                                  Grid.ColumnSpan="3"
                                                                  Margin="0,0,0,6">

                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- [MCB 통신] 설정 제목 -->
                                                                <TextBlock Grid.Column="0"
                                                                           Text="MCB 통신 설정"
                                                                           Foreground="White"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"/>

                                                                <!-- [MCB 연결] 상태 표시 -->
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding McbConnectionStatusText}"
                                                                           Foreground="{Binding McbConnectionStatusBrush}"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"/>
                                                            </Grid>

                                                            <!-- [MCB IP] 입력 -->
                                                            <TextBox Grid.Row="1"
                                                                     Grid.Column="1"
                                                                     Text="{Binding McbIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsEnabled="{Binding IsDeviceConnectionSettingEnabled}"
                                                                     Height="24"
                                                                     FontSize="12"
                                                                     FontWeight="Bold"
                                                                     VerticalContentAlignment="Center"
                                                                     Margin="0,0,5,0"/>

                                                            <!-- [MCB Port] 입력 -->
                                                            <TextBox Grid.Row="1"
                                                                     Grid.Column="2"
                                                                     Text="{Binding McbPort, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsEnabled="{Binding IsDeviceConnectionSettingEnabled}"
                                                                     Height="24"
                                                                     FontSize="12"
                                                                     FontWeight="Bold"
                                                                     VerticalContentAlignment="Center"/>
                                                        </Grid>

                                                    </Border>

                                                    <!-- [SCB 통신] 설정 영역 -->
                                                    <Border Background="#40464D"
                                                            BorderBrush="#95A5B0"
                                                            BorderThickness="1"
                                                            Padding="8">

                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <!-- [SCB 제목 / 상태] 표시 -->
                                                                <RowDefinition Height="Auto"/>

                                                                <!-- [SCB IP / Port] 입력 -->
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <Grid.ColumnDefinitions>
                                                                <!-- 여백용 Column -->
                                                                <ColumnDefinition Width="Auto"/>

                                                                <!-- IP 입력 Column -->
                                                                <ColumnDefinition Width="*"/>

                                                                <!-- Port 입력 Column -->
                                                                <ColumnDefinition Width="65"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- [SCB 제목 및 연결 상태] 표시 -->
                                                            <Grid Grid.Row="0"
                                                                  Grid.Column="0"
                                                                  Grid.ColumnSpan="3"
                                                                  Margin="0,0,0,6">

                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- [SCB 통신] 설정 제목 -->
                                                                <TextBlock Grid.Column="0"
                                                                           Text="SCB 통신 설정"
                                                                           Foreground="White"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"/>

                                                                <!-- [SCB 연결] 상태 표시 -->
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding ScbConnectionStatusText}"
                                                                           Foreground="{Binding ScbConnectionStatusBrush}"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"/>
                                                            </Grid>

                                                            <!-- [SCB IP] 입력 -->
                                                            <TextBox Grid.Row="1"
                                                                     Grid.Column="1"
                                                                     Text="{Binding ScbIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsEnabled="{Binding IsDeviceConnectionSettingEnabled}"
                                                                     Height="24"
                                                                     FontSize="12"
                                                                     FontWeight="Bold"
                                                                     VerticalContentAlignment="Center"
                                                                     Margin="0,0,5,0"/>

                                                            <!-- [SCB Port] 입력 -->
                                                            <TextBox Grid.Row="1"
                                                                     Grid.Column="2"
                                                                     Text="{Binding ScbPort, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsEnabled="{Binding IsDeviceConnectionSettingEnabled}"
                                                                     Height="24"
                                                                     FontSize="12"
                                                                     FontWeight="Bold"
                                                                     VerticalContentAlignment="Center"/>
                                                        </Grid>

                                                    </Border>

                                                </StackPanel>

                                            </Border>

                                            <!-- [PTZ 제어 모드 영역] -->
                                            <Border Margin="0,0,0,10"
                                                    Background="#5F666D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1.5"
                                                    CornerRadius="5"
                                                    Padding="10">

                                                <StackPanel>

                                                    <!-- [PTZ 제어 모드 제목] -->
                                                    <TextBlock Text="PTZ CONTROL MODE"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,8"/>

                                                    <!-- [현재 PTZ 제어 모드 표시] -->
                                                    <TextBlock Text="{Binding PtzControlModeText, StringFormat=CURRENT MODE : {0}}"
                                                                              HorizontalAlignment="Center"
                                                                              Foreground="#D0D7DE"
                                                                              FontSize="12"
                                                                              FontWeight="Bold"
                                                                              Margin="0,0,0,8"/>

                                                    <!-- [PTZ 제어 모드 버튼 영역] -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- [AUTO] 모드 설정 -->
                                                        <Button Grid.Column="0"
                                                                Content="AUTO"
                                                                Height="26"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Command="{Binding SetPtzAutoModeCommand}"/>

                                                        <!-- [MANUAL] 모드 설정 -->
                                                        <Button Grid.Column="2"
                                                                Content="MANUAL"
                                                                Height="26"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Command="{Binding SetPtzManualModeCommand}"/>
                                                    </Grid>

                                                </StackPanel>
                                            </Border>

                                            <!-- [PAN / TILT] 연속 이동 제어 영역 -->
                                            <Border Margin="0,0,0,5"
                                                    Background="#5F666D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1.5"
                                                    CornerRadius="5"
                                                    Padding="10">

                                                <StackPanel>

                                                    <!-- [PAN / TILT] 제어 제목 -->
                                                    <TextBlock Text="PAN / TILT CONTROL"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,10"/>

                                                    <!--
                                                        [PAN / TILT] 방향 버튼 영역

                                                        1) MouseDown : 이동 시작
                                                        2) MouseUp   : 이동 정지
                                                        3) MouseLeave: 이동 정지
                                                    -->
                                                    <Grid Width="120"
                                                          Height="120"
                                                          HorizontalAlignment="Center">

                                                        <Grid.RowDefinitions>
                                                            <RowDefinition/>
                                                            <RowDefinition/>
                                                            <RowDefinition/>
                                                        </Grid.RowDefinitions>

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- [Tilt 위쪽] 연속 이동 -->
                                                        <Button Grid.Row="0"
                                                                Grid.Column="1"
                                                                Content="▲"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Style="{StaticResource PanTiltDirectionButtonStyle}"
                                                                PreviewMouseDown="TiltUp_MouseDown"
                                                                PreviewMouseUp="MoveStop_MouseUp"
                                                                MouseLeave="MoveStop_MouseUp"/>

                                                        <!-- [Pan 왼쪽] 연속 이동 -->
                                                        <Button Grid.Row="1"
                                                                Grid.Column="0"
                                                                Content="◀"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Style="{StaticResource PanTiltDirectionButtonStyle}"
                                                                PreviewMouseDown="PanLeft_MouseDown"
                                                                PreviewMouseUp="MoveStop_MouseUp"
                                                                MouseLeave="MoveStop_MouseUp"/>

                                                        <!-- [PAN / TILT 정지] 버튼 영역 -->
                                                        <Border Grid.Row="1"
                                                                Grid.Column="1"
                                                                Margin="5"
                                                                Background="#3F454B"
                                                                BorderBrush="#8B949E"
                                                                BorderThickness="1">

                                                            <!-- [PAN / TILT 정지] -->
                                                            <Button Content="STOP"
                                                                    Style="{StaticResource StopButtonStyle}"
                                                                    IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                    Command="{Binding StopMoveCommand}"/>
                                                        </Border>

                                                        <!-- [Pan 오른쪽] 연속 이동 -->
                                                        <Button Grid.Row="1"
                                                                Grid.Column="2"
                                                                Content="▶"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Style="{StaticResource PanTiltDirectionButtonStyle}"
                                                                PreviewMouseDown="PanRight_MouseDown"
                                                                PreviewMouseUp="MoveStop_MouseUp"
                                                                MouseLeave="MoveStop_MouseUp"/>

                                                        <!-- [Tilt 아래쪽] 연속 이동 -->
                                                        <Button Grid.Row="2"
                                                                Grid.Column="1"
                                                                Content="▼"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Style="{StaticResource PanTiltDirectionButtonStyle}"
                                                                PreviewMouseDown="TiltDown_MouseDown"
                                                                PreviewMouseUp="MoveStop_MouseUp"
                                                                MouseLeave="MoveStop_MouseUp"/>
                                                    </Grid>

                                                    <!-- [PAN / TILT] 연속 이동 속도 설정 -->
                                                    <StackPanel Margin="0,5,0,0">

                                                        <!-- [PAN / TILT] 현재 속도 표시 -->
                                                        <TextBlock Text="{Binding PanTiltSpeedLevel, StringFormat=PT SPEED LV : {0:F0} deg/s}"
                                                                                  Foreground="#D0D7DE"
                                                                                  FontSize="12"
                                                                                  FontWeight="Bold"
                                                                                  HorizontalAlignment="Center"
                                                                                  Margin="0,0,0,5"/>

                                                        <!-- [PAN / TILT] 속도 조절 [Slider] -->
                                                        <!-- [Slider] 눈금 표시 -->
                                                        <Slider Minimum="0"
                                                                Maximum="100"
                                                                TickFrequency="5"
                                                                SmallChange="5"
                                                                LargeChange="10"
                                                                TickPlacement="BottomRight"
                                                                IsSnapToTickEnabled="True"
                                                                Value="{Binding PanTiltSpeedLevel, 
                                                                                Mode=TwoWay, 
                                                                                UpdateSourceTrigger=PropertyChanged}"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Width="220"/>

                                                    </StackPanel>

                                                </StackPanel>

                                            </Border>

                                            <!-- [ZOOM / FOCUS] 연속 제어 영역 -->
                                            <Border Margin="0,0,0,5"
                                                    Background="#5F666D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1.5"
                                                    CornerRadius="5"
                                                    Padding="10">

                                                <StackPanel>

                                                    <!-- [ZOOM / FOCUS] 제어 제목 -->
                                                    <TextBlock Text="ZOOM / FOCUS CONTROL"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,10"/>

                                                    <!-- [Zoom] 연속 제어 버튼 영역 -->
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center"
                                                                Margin="0,0,0,10">

                                                        <!-- [Zoom Tele] 연속 이동 -->
                                                        <Button Content="ZOOM +"
                                                                Width="85"
                                                                Margin="5"
                                                                Focusable="False"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Style="{StaticResource EoControlButtonStyle}"
                                                                PreviewMouseDown="ZoomIn_MouseDown"
                                                                PreviewMouseUp="MoveStop_MouseUp"
                                                                MouseLeave="MoveStop_MouseUp"/>

                                                        <!-- [Zoom Wide] 연속 이동 -->
                                                        <Button Content="ZOOM -"
                                                                Width="85"
                                                                Margin="5"
                                                                Focusable="False"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Style="{StaticResource EoControlButtonStyle}"
                                                                PreviewMouseDown="ZoomOut_MouseDown"
                                                                PreviewMouseUp="MoveStop_MouseUp"
                                                                MouseLeave="MoveStop_MouseUp"/>
                                                    </StackPanel>

                                                    <!-- [Focus] 연속 제어 버튼 영역 -->
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center"
                                                                Margin="0,0,0,10">

                                                        <!-- [Focus Far] 연속 이동 -->
                                                        <Button Content="FOCUS +"
                                                                Width="85"
                                                                Margin="5"
                                                                Focusable="False"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Style="{StaticResource EoControlButtonStyle}"
                                                                PreviewMouseDown="FocusFar_MouseDown"
                                                                PreviewMouseUp="MoveStop_MouseUp"
                                                                MouseLeave="MoveStop_MouseUp"/>

                                                        <!-- [Focus Near] 연속 이동 -->
                                                        <Button Content="FOCUS -"
                                                                Width="85"
                                                                Margin="5"
                                                                Focusable="False"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Style="{StaticResource EoControlButtonStyle}"
                                                                PreviewMouseDown="FocusNear_MouseDown"
                                                                PreviewMouseUp="MoveStop_MouseUp"
                                                                MouseLeave="MoveStop_MouseUp"/>
                                                    </StackPanel>

                                                    <!-- [Auto Focus] 실행 -->
                                                    <Button Content="AUTO FOCUS"
                                                            Width="180"
                                                            Margin="5"
                                                            HorizontalAlignment="Center"
                                                            IsEnabled="{Binding IsDeviceControlEnabled}"
                                                            Style="{StaticResource AutoFocusButtonStyle}"
                                                            Command="{Binding AutoFocusCommand}"/>
                                                </StackPanel>

                                            </Border>

                                            <!-- 현재 장비 상태 표시 영역 -->
                                            <Border Margin="0,0,0,0"
                                                    Background="#40464D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1"
                                                    CornerRadius="5"
                                                    Padding="10">

                                                <StackPanel Margin="0,5,0,0">

                                                    <!-- 현재 장비 상태 제목 -->
                                                    <TextBlock Text="CURRENT STATUS"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,15"/>

                                                    <!-- [Pan] 현재 위치 -->
                                                    <Grid Margin="0,1,0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="45"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="Pan"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text=":"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding CurrentPan, StringFormat={}{0:F4}}"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>
                                                    </Grid>

                                                    <!-- [Tilt] 현재 위치 -->
                                                    <Grid Margin="0,1,0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="45"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="Tilt"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text=":"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding CurrentTilt, StringFormat={}{0:F4}}"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>
                                                    </Grid>

                                                    <!-- [Zoom] 현재 위치 -->
                                                    <Grid Margin="0,1,0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="45"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="Zoom"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text=":"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding CurrentZoom}"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>
                                                    </Grid>

                                                    <!-- [Focus] 현재 위치 -->
                                                    <Grid Margin="0,1,0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="45"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="Focus"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text=":"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding CurrentFocus}"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"/>
                                                    </Grid>

                                                </StackPanel>

                                            </Border>

                                        </StackPanel>

                                    </ScrollViewer>

                                </TabItem>

                                <!--
                                    [PAN / TILT] Tab
                                
                                    1) [Continue] 이동
                                    2) [Absolute] 이동
                                    3) [Relative] 이동
                                    4) [Home / Zero] 기능
                                    5) [Input Reset] 기능을 제공한다.
                                -->
                                <TabItem Header="위치 제어">

                                    <!-- [PAN / TILT] Tab 내부 [Scroll 영역] -->
                                    <ScrollViewer VerticalScrollBarVisibility="Visible"
                                                  HorizontalScrollBarVisibility="Disabled">

                                        <StackPanel Margin="5">

                                            <!-- [Absolute] 위치 이동 영역 -->
                                            <Border Margin="0,0,0,10"
                                                    Background="#5F666D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1.5"
                                                    CornerRadius="5"
                                                    Padding="10">

                                                <StackPanel>

                                                    <!-- [Absolute] 이동 제목 -->
                                                    <TextBlock Text="ABSOLUTE MOVE"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,5"/>

                                                    <!-- [Pan Absolute] 목표 각도 입력 라벨 -->
                                                    <TextBlock Text="Pan Target"
                                                               Foreground="White"
                                                               FontSize="12"/>

                                                    <!-- [Pan Absolute] 목표 각도 입력 -->
                                                    <TextBox Text="{Binding PanAbsoluteValue, 
                                                                            UpdateSourceTrigger=LostFocus, 
                                                                            TargetNullValue='0',
                                                                            FallbackValue=''}"
                                                             PreviewTextInput="DecimalNumberOnly_PreviewTextInput"
                                                             LostFocus="PanAngle_LostFocus"
                                                             IsEnabled="{Binding IsDeviceControlEnabled}"
                                                             Height="24"
                                                             Margin="0,3,0,5"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"/>

                                                    <!-- [Pan Absolute] 이동 실행 -->
                                                    <Button Content="PAN GO"
                                                            Height="30"
                                                            Margin="0,0,0,10"
                                                            IsEnabled="{Binding IsDeviceControlEnabled}"
                                                            Style="{StaticResource EoControlButtonStyle}"
                                                            Command="{Binding MovePanAbsoluteCommand}"/>

                                                    <!-- [Tilt Absolute] 목표 각도 입력 라벨 -->
                                                    <TextBlock Text="Tilt Target"
                                                               Foreground="White"
                                                               FontSize="12"/>

                                                    <!-- [Tilt Absolute] 목표 각도 입력 -->
                                                    <TextBox Text="{Binding TiltAbsoluteValue, 
                                                                            UpdateSourceTrigger=LostFocus, 
                                                                            TargetNullValue='0',
                                                                            FallbackValue=''}"
                                                             PreviewTextInput="DecimalNumberOnly_PreviewTextInput"
                                                             LostFocus="TiltAngle_LostFocus"
                                                             IsEnabled="{Binding IsDeviceControlEnabled}"
                                                             Height="24"
                                                             Margin="0,3,0,5"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"/>

                                                    <!-- [Tilt Absolute] 이동 실행 -->
                                                    <Button Content="TILT GO"
                                                            Height="30"
                                                            Style="{StaticResource EoControlButtonStyle}"
                                                            IsEnabled="{Binding IsDeviceControlEnabled}"
                                                            Command="{Binding MoveTiltAbsoluteCommand}"/>
                                                </StackPanel>

                                            </Border>

                                            <!-- [Relative] 위치 이동 영역 -->
                                            <Border Margin="0,0,0,10"
                                                    Background="#5F666D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1.5"
                                                    CornerRadius="5"
                                                    Padding="10">

                                                <StackPanel>

                                                    <!-- [Relative] 이동 제목 -->
                                                    <TextBlock Text="RELATIVE MOVE"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,5"/>

                                                    <!-- [Pan Relative] 이동 각도 입력 라벨 -->
                                                    <TextBlock Text="Pan Relative"
                                                               Foreground="White"
                                                               FontSize="12"/>

                                                    <!-- [Pan Relative] 이동 각도 입력 -->
                                                    <TextBox Text="{Binding PanRelativeValue, 
                                                                            UpdateSourceTrigger=LostFocus, 
                                                                            TargetNullValue='0',
                                                                            FallbackValue=''}"
                                                             PreviewTextInput="RelativeDecimalNumberOnly_PreviewTextInput"
                                                             IsEnabled="{Binding IsDeviceControlEnabled}"
                                                             Height="24"
                                                             Margin="0,3,0,5"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"/>

                                                    <!-- [Pan Relative] 이동 실행 -->
                                                    <Button Content="PAN RELATIVE"
                                                            Height="30"
                                                            Margin="0,0,0,10"
                                                            Style="{StaticResource EoControlButtonStyle}"
                                                            IsEnabled="{Binding IsDeviceControlEnabled}"
                                                            Command="{Binding MovePanRelativeCommand}"/>

                                                    <!-- [Tilt Relative] 이동 각도 입력 라벨 -->
                                                    <TextBlock Text="Tilt Relative"
                                                               Foreground="White"
                                                               FontSize="12"/>

                                                    <!-- [Tilt Relative] 이동 각도 입력 -->
                                                    <TextBox Text="{Binding TiltRelativeValue, 
                                                                            UpdateSourceTrigger=LostFocus, 
                                                                            TargetNullValue='0',
                                                                            FallbackValue=''}"
                                                             PreviewTextInput="RelativeDecimalNumberOnly_PreviewTextInput"
                                                             IsEnabled="{Binding IsDeviceControlEnabled}"
                                                             Height="24"
                                                             Margin="0,3,0,5"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"/>

                                                    <!-- [Tilt Relative] 이동 실행 -->
                                                    <Button Content="TILT RELATIVE"
                                                            Height="30"
                                                            Style="{StaticResource EoControlButtonStyle}"
                                                            IsEnabled="{Binding IsDeviceControlEnabled}"
                                                            Command="{Binding MoveTiltRelativeCommand}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- [Zoom / Focus] 위치 제어 영역 -->
                                            <Border Margin="0,0,0,10"
                                                    Background="#5F666D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1.5"
                                                    CornerRadius="5"
                                                    Padding="10">

                                                <StackPanel>

                                                    <!-- [Position Control] 제목 -->
                                                    <TextBlock Text="POSITION CONTROL"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,5"/>

                                                    <!-- [Zoom] 목표 위치 입력 라벨 -->
                                                    <TextBlock Text="Zoom Position"
                                                               Foreground="White"
                                                               FontSize="12"/>

                                                    <!-- [Zoom] 목표 위치 입력 -->
                                                    <TextBox Text="{Binding ZoomPositionValue, 
                                                                            UpdateSourceTrigger=LostFocus,
                                                                            TargetNullValue='0',
                                                                            FallbackValue=''}"
                                                             PreviewTextInput="IntegerNumberOnly_PreviewTextInput"
                                                             LostFocus="PositionValue_LostFocus"
                                                             IsEnabled="{Binding IsDeviceControlEnabled}"
                                                             Height="24"
                                                             Margin="0,3,0,5"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"/>

                                                    <!-- [Zoom] 위치 이동 실행 -->
                                                    <Button Content="SET ZOOM"
                                                            Height="30"
                                                            Margin="0,0,0,10"
                                                            Style="{StaticResource EoControlButtonStyle}"
                                                            IsEnabled="{Binding IsDeviceControlEnabled}"
                                                            Command="{Binding SetZoomPositionCommand}"/>

                                                    <!-- [Focus] 목표 위치 입력 라벨 -->
                                                    <TextBlock Text="Focus Position"
                                                               Foreground="White"
                                                               FontSize="12"/>

                                                    <!-- [Focus] 목표 위치 입력 -->
                                                    <TextBox Text="{Binding FocusPositionValue, 
                                                                            UpdateSourceTrigger=LostFocus,
                                                                            TargetNullValue='0',
                                                                            FallbackValue=''}"
                                                             PreviewTextInput="IntegerNumberOnly_PreviewTextInput"
                                                             LostFocus="PositionValue_LostFocus"
                                                             IsEnabled="{Binding IsDeviceControlEnabled}"
                                                             Height="24"
                                                             Margin="0,3,0,5"
                                                             FontWeight="Bold"
                                                             VerticalContentAlignment="Center"/>

                                                    <!-- [Focus] 위치 이동 실행 -->
                                                    <Button Content="SET FOCUS"
                                                            Height="30"
                                                            Style="{StaticResource EoControlButtonStyle}"
                                                            IsEnabled="{Binding IsDeviceControlEnabled}"
                                                            Command="{Binding SetFocusPositionCommand}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- [Home / Zero] 제어 영역 -->
                                            <Border Margin="0,0,0,5"
                                                    Background="#5F666D"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1.5"
                                                    CornerRadius="5"
                                                    Padding="10">

                                                <StackPanel>

                                                    <!-- [Home / Zero] 제목 -->
                                                    <TextBlock Text="HOME / ZERO"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,10"/>

                                                    <!--
                                                        [Home Position] 이동

                                                        1) [Set0]가 아니라
                                                        2) 실제 [Pan / Tilt]를 0도 위치로 이동한다.
                                                    -->
                                                    <Button Content="HOME POSITION"
                                                            Height="30"
                                                            Margin="0,0,0,5"
                                                            Style="{StaticResource AutoFocusButtonStyle}"
                                                            IsEnabled="{Binding IsDeviceControlEnabled}"
                                                            Command="{Binding MoveHomePositionCommand}"/>

                                                    <!-- [Pan / Tilt Zero] 버튼 배치 영역 -->
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center">

                                                        <!-- [Pan 현재 위치]를 0으로 재정의 -->
                                                        <Button Content="PAN ZERO"
                                                                Width="85"
                                                                Margin="5"
                                                                Style="{StaticResource EoControlButtonStyle}"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Command="{Binding SetPanZeroCommand}"/>

                                                        <!-- [Tilt 현재 위치]를 0으로 재정의 -->
                                                        <Button Content="TILT ZERO"
                                                                Width="85"
                                                                Margin="5"
                                                                Style="{StaticResource EoControlButtonStyle}"
                                                                IsEnabled="{Binding IsDeviceControlEnabled}"
                                                                Command="{Binding SetTiltZeroCommand}"/>
                                                    </StackPanel>

                                                </StackPanel>

                                            </Border>

                                            <!-- [입력값 초기화 영역] -->
                                            <Border Margin="0,10,0,0"
                                                    Background="#6A7178"
                                                    BorderBrush="#95A5B0"
                                                    BorderThickness="1"
                                                    CornerRadius="5"
                                                    Padding="8">

                                                <StackPanel>

                                                    <!-- [입력값 초기화] 제목 -->
                                                    <TextBlock Text="INPUT CONTROL"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               Margin="0,0,0,8"/>

                                                    <!-- [위치 제어 입력값 초기화] -->
                                                    <Button Content="RESET INPUT"
                                                            Height="30"
                                                            Style="{StaticResource EoControlButtonStyle}"
                                                            IsEnabled="{Binding IsDeviceControlEnabled}"
                                                            Command="{Binding ResetPositionInputCommand}"/>

                                                </StackPanel>

                                            </Border>

                                        </StackPanel>

                                    </ScrollViewer>

                                </TabItem>

                            </TabControl>

                        </Grid>

                    </Border>

                </Grid>

            </Border>

        </Grid>

        <!-- 하단 상태 바 -->
        <Border Grid.Row="2"
                Padding="10"
                Margin="0,10,0,0"
                Background="#2B3038">
            <TextBlock Text="CSE Middleware Test UI - Console log enabled"
                       Foreground="#B8C7D9"
                       FontSize="14"/>
        </Border>

    </Grid>

</Window>